# --- Secrets ---
.env
.env.*
!.env.example

# --- Local session resume (IMPORTANT: do not delete casually) ---
# 保存当前 Grok/CLI 会话 id，用于下次 `grok --resume ...` 续聊。
# 仅本地使用，不进版本库。
session.txt

# --- Runtime logs ---
logs/
*.log

# --- Virtual environments (uv uses .venv) ---
.venv/
venv/
env/
ENV/
.path/
path/

# --- Python bytecode / caches ---
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

