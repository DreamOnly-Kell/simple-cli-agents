# OpenAI-compatible Chat Completions endpoint
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# File tools sandbox (absolute or relative path)
WORKSPACE_ROOT=.

# Console logical traces (learning)
VERBOSE=1
VERBOSE_FULL=0

# HTTP wire logs (jsonl under HTTP_LOG_DIR)
HTTP_LOG=1
HTTP_LOG_DIR=logs

# Shell tool policy (run_command)
# Patterns separated by ||  (substring match, case-insensitive).
# Leave unset to use built-in defaults (rm -rf /, sudo, mkfs, ...).
# Set to "none" to disable blocking (not recommended).
# SHELL_BLOCKED_PATTERNS=rm -rf /||sudo ||mkfs||shutdown
SHELL_TIMEOUT_SECONDS=30
